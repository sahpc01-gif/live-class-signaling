# این فایل را به .env کپی کنید (یا مستقیماً همین مقادیر را در
# بخش Environment سرویس Render.com وارد کنید) و مقادیر واقعی را
# جایگزین کنید.

# باید دقیقاً همان مقدار "کلید مخفی مشترک" باشد که در پیشخوان وردپرس
# (افزونه Online Classroom > تنظیمات) نشان داده می‌شود.
JWT_SECRET=

# آدرس کامل سایت وردپرس شما (بدون / در پایان)
WP_SITE_URL=https://example.com

# آدرس سایت وردپرس که اجازه دارد به این سرور وصل شود (CORS).
# برای امنیت بهتر، به‌جای * آدرس دقیق سایت را قرار دهید.
ALLOWED_ORIGIN=https://example.com

# پورتی که سرور روی آن اجرا می‌شود. Render.com معمولاً خودش این را تنظیم می‌کند.
PORT=10000

# حداکثر تعداد دانش‌آموز در هر اتاق (باید با تنظیمات افزونه هماهنگ باشد)
MAX_STUDENTS_PER_ROOM=30
